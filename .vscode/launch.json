{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run T3 Code VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode"],
      "outFiles": ["${workspaceFolder}/apps/vscode/dist/**/*.cjs"],
      "preLaunchTask": "build-vscode-extension"
    }
  ]
}
